# YNX v2 local/public-testnet environment template

# Core chain
YNX_CHAIN_ID=ynx_9102-1
YNX_EVM_CHAIN_ID=9102
YNX_DENOM=anyxt
YNX_MONIKER=ynx-v2-web4

# Local ports
YNX_P2P_PORT=36656
YNX_RPC_PORT=36657
YNX_REST_PORT=31317
YNX_GRPC_PORT=39090
YNX_EVM_PORT=38545
YNX_EVM_WS_PORT=38546
YNX_PROM_PORT=36660
YNX_PPROF_PORT=36661
YNX_GETH_METRICS_PORT=38100

# Infra ports
FAUCET_PORT=38080
INDEXER_PORT=38081
EXPLORER_PORT=38082
AI_GATEWAY_PORT=38090
WEB4_PORT=38091

# Web4 defaults
WEB4_TRACK=v2-web4
WEB4_ENFORCE_POLICY=0
WEB4_INTENT_TTL_SEC=900
WEB4_DEFAULT_SESSION_TTL_SEC=900
WEB4_DEFAULT_MAX_OPS=50
WEB4_DEFAULT_MAX_SPEND=10000

# AI settlement defaults
AI_DEFAULT_CHALLENGE_BLOCKS=120
AI_X402_UNIT_PRICE=1
AI_X402_DENOM=usdc

# Faucet defaults
FAUCET_KEY=faucet
FAUCET_KEYRING=os
FAUCET_AMOUNT=1000000000000000000
FAUCET_GAS_PRICES=0.000000007anyxt

# Optional on-chain metadata
YNX_FOUNDER_ADDRESS=
YNX_TREASURY_ADDRESS=
YNX_TEAM_BENEFICIARY=
YNX_COMMUNITY_RECIPIENT=
