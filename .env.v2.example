# YNX v2 local/public-testnet environment template
# Copy this file to .env for local operation. Keep real .env files out of git.

# Core chain
YNX_CHAIN_ID=ynx_9102-1
YNX_EVM_CHAIN_ID=9102
YNX_DENOM=anyxt
YNX_MONIKER=ynx-v2-web4

# Canonical public v2 endpoints
YNX_PUBLIC_RPC=https://rpc.ynxweb4.com
YNX_PUBLIC_EVM_RPC=https://evm.ynxweb4.com
YNX_PUBLIC_REST=https://rest.ynxweb4.com
YNX_PUBLIC_GRPC=https://grpc.ynxweb4.com
YNX_PUBLIC_FAUCET=https://faucet.ynxweb4.com
YNX_PUBLIC_INDEXER=https://indexer.ynxweb4.com
YNX_PUBLIC_EXPLORER=https://explorer.ynxweb4.com
YNX_PUBLIC_AI_GATEWAY=https://ai.ynxweb4.com
YNX_PUBLIC_WEB4_HUB=https://web4.ynxweb4.com
YNX_PUBLIC_BRIDGE=https://bridge.ynxweb4.com

# Local ports
YNX_P2P_PORT=36656
YNX_RPC_PORT=36657
YNX_REST_PORT=31317
YNX_GRPC_PORT=39090
YNX_EVM_PORT=38545
YNX_EVM_WS_PORT=38546
YNX_PROM_PORT=36660
YNX_PPROF_PORT=36661
YNX_GETH_METRICS_PORT=38100

# Infra ports
FAUCET_PORT=38080
INDEXER_PORT=38081
EXPLORER_PORT=38082
BRIDGE_PORT=38083
AI_GATEWAY_PORT=38090
WEB4_PORT=38091

# Web4 defaults
WEB4_TRACK=v2-web4
WEB4_ENFORCE_POLICY=0
WEB4_INTENT_TTL_SEC=900
WEB4_DEFAULT_SESSION_TTL_SEC=900
WEB4_DEFAULT_MAX_OPS=50
WEB4_DEFAULT_MAX_SPEND=10000

# AI settlement defaults
AI_DEFAULT_CHALLENGE_BLOCKS=120
AI_X402_UNIT_PRICE=1
AI_X402_DENOM=usdc
AI_ONCHAIN_ENABLED=0
AI_ONCHAIN_RPC_URL=https://evm.ynxweb4.com
AI_SETTLEMENT_CONTRACT=0x87e8a50880584abaB283cDeC18d884A7BDc42Fcf
# Set only in a private runtime environment. Never commit the real key.
AI_ONCHAIN_PRIVATE_KEY=
AI_ONCHAIN_CONFIRMATIONS=1

# Cross-chain testnet bridge defaults
BRIDGE_YNX_RPC_URL=https://evm.ynxweb4.com
BRIDGE_GATEWAY_ADDRESS=0x3a2948da8f35b86dce1440ebfb56b8ae041cebfe
BRIDGE_ROUTES_FILE=
BRIDGE_ONCHAIN_ENABLED=0
BRIDGE_RELAYER_MODE=remote
BRIDGE_REMOTE_SIGNER_ADDRESS=
BRIDGE_ATTESTER_PRIVATE_KEY=
BRIDGE_RELAYER_PRIVATE_KEY=
BRIDGE_CONFIRMATIONS=1
BRIDGE_REQUIRE_OPERATOR_TOKEN=1
BRIDGE_OPERATOR_TOKEN=

# Faucet defaults
FAUCET_KEY=faucet
FAUCET_KEYRING=os
FAUCET_AMOUNT=1000000000000000000
FAUCET_GAS_PRICES=0.000000007anyxt

# Optional on-chain metadata
YNX_FOUNDER_ADDRESS=
YNX_TREASURY_ADDRESS=
YNX_TEAM_BENEFICIARY=
YNX_COMMUNITY_RECIPIENT=
