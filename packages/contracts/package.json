{
  "name": "@ynx/contracts",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "devnet:node": "hardhat node --hostname 127.0.0.1 --port 8545",
    "devnet:deploy": "hardhat run scripts/deploy.ts --network localhost",
    "ynxdev:deploy": "hardhat run scripts/deploy.ts --network ynxdev",
    "ynxpublic:ai-settlement": "hardhat run scripts/deploy_ai_settlement.ts --network ynxpublic",
    "ynxdev:bridge-deploy": "hardhat run scripts/deploy_bridge.ts --network ynxdev",
    "ynxpublic:bridge-mainstream": "hardhat run scripts/deploy_mainstream_bridge.ts --network ynxpublic",
    "ynxpublic:yusd-test": "hardhat run scripts/deploy_yusd_test.ts --network ynxpublic",
    "ynxpublic:testnet-amm": "hardhat run scripts/deploy_testnet_amm.ts --network ynxpublic",
    "ynxpublic:bridge-testnet-routes": "hardhat run scripts/set_testnet_bridge_routes.ts --network ynxpublic",
    "source:lockbox": "hardhat run scripts/deploy_source_lockbox.ts",
    "bridge:tron-manifest": "hardhat run scripts/generate_tron_manifest.ts --network default",
    "ynxdev:bridge-onboard": "hardhat run scripts/onboard_assets_from_manifest.ts --network ynxdev",
    "ynxdev:governance-e2e": "hardhat run scripts/ynxdev/governance_e2e.ts --network ynxdev",
    "ynxdev:domain-inbox-demo": "hardhat run scripts/ynxdev/domain_inbox_demo.ts --network ynxdev",
    "deploy:sim": "hardhat run scripts/deploy.ts --network default",
    "test": "hardhat test",
    "lint": "node ../../node_modules/eslint/bin/eslint.js .",
    "format": "prettier -w ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nomicfoundation/hardhat-ethers": "^4.0.5",
    "@nomicfoundation/hardhat-mocha": "^3.0.9",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.3",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "chai": "^6.2.2",
    "eslint": "^10.0.0",
    "globals": "^17.4.0",
    "hardhat": "^3.1.7",
    "mocha": "^11.0.0",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1"
  }
}
